{
  "name": "markdown-studio",
  "version": "1.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "build:app": "bun run scripts/build-app.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "prepare": "bun run scripts/ensure-generated.ts",
    "build:dmg": "bun run scripts/build-app.ts --dmg"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource-variable/schibsted-grotesk": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tiptap/extension-character-count": "^2",
    "@tiptap/extension-color": "^2",
    "@tiptap/extension-highlight": "^2",
    "@tiptap/extension-image": "^2",
    "@tiptap/extension-link": "^2",
    "@tiptap/extension-placeholder": "^2",
    "@tiptap/extension-table": "^2",
    "@tiptap/extension-table-cell": "^2",
    "@tiptap/extension-table-header": "^2",
    "@tiptap/extension-table-row": "^2",
    "@tiptap/extension-task-item": "^2",
    "@tiptap/extension-task-list": "^2",
    "@tiptap/extension-text-style": "^2",
    "@tiptap/extension-underline": "^2",
    "@tiptap/react": "^2",
    "@tiptap/starter-kit": "^2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tiptap-markdown": "^0.9.0",
    "webview-bun": "^2.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@tiptap/core": "^2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "description": "Visualizador e editor de Markdown para macOS: abre arquivos .md renderizados e editáveis, com modo código, abas, busca e exportação para PDF, HTML, DOCX e RTF."
}
